# GEMINI_API_KEY: Required for Gemini AI API calls.
# AI Studio automatically injects this at runtime from user secrets.
# Users configure this via the Secrets panel in the AI Studio UI.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="MY_APP_URL"

# ACCESS_PASSWORD: Simple PIN or password to keep the database private.
ACCESS_PASSWORD=

# ACTION_PASSWORD: Password required for critical actions (delete record, add match)
ACTION_PASSWORD=

# SUPABASE_URL: Your Supabase Project URL (provided by the user)
SUPABASE_URL=

# SUPABASE_ANON_KEY: Your Supabase Anonymous API key (or Service Role key for server-side work)
SUPABASE_ANON_KEY=

# VITE_ACCESS_PASSWORD / VITE_ACTION_PASSWORD: used only for the static
# (GitHub Pages) build, where there is no backend server. These end up
# compiled into the public JS bundle at build time — anyone who opens
# devtools can read them, so they only gate casual visitors, not a
# determined attacker. Set the real values as GitHub Actions repository
# secrets, never commit them here.
VITE_ACCESS_PASSWORD=
VITE_ACTION_PASSWORD=

# VITE_SUPABASE_URL / VITE_SUPABASE_ANON_KEY: also only for the static
# (GitHub Pages) build. Unlike the passwords above, these are meant to be
# public — the anon key only identifies the app, actual write access still
# goes through the same PIN gate in the UI. Same values as SUPABASE_URL /
# SUPABASE_ANON_KEY above, set as GitHub Actions repository secrets.
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=
